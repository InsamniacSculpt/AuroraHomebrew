<?xml version="1.0" encoding="utf-8" ?>
<elements>
	<info>
		<name>Hex</name>
		<author url="https://www.youtube.com/@InsamniacFilms">Insamniac</author>
		<update version="0.1">
			<file name="item-hex.xml" url="https://raw.githubusercontent.com/insamniacsculpt/aurora2020on/master/item-hex.xml" />
		</update>
	</info>
	<element name="Hex Purity 1" type="Magic Item" source="Nullification of Novus" id="ID_ITEM_HEX_PURITY_1">
		<supports>ID_INTERNAL_HEX_PURITY</supports>
		<description>
			<p>A vial of a magic drug that empowers the user with the ability to cast a single Level 1 spell of the defined Hex type, and any cantrips.</p>	
		</description>
		<setters>
			<set name="category">Hex Purity</set>
			<set name="cost" currency="gp">15</set>
			<set name="weight" lb="8">0.2 lbs.</set>
			<set name="type">Hex</set>
			<set name="rarity">Common</set>
		</setters>
	</element>

		<element name="Hex Purity 2" type="Magic Item" source="Nullification of Novus" id="ID_ITEM_HEX_PURITY_2">
		<supports>ID_INTERNAL_HEX_PURITY</supports>
		<description>
			<p>A vial of a magic drug that empowers the user with the ability to cast a single Level 2 spell of the defined Hex type, and any cantrips.</p>	
		</description>
		<setters>
			<set name="category">Hex Purity</set>
			<set name="cost" currency="gp">15</set>
			<set name="weight" lb="8">0.2 lbs.</set>
			<set name="type">Hex</set>
			<set name="rarity">Uncommon</set>
		</setters>
	</element>
	
	<element name="Evocation" type="Magic Item" source="Nullification of Novus" id="ID_ITEM_HEX_EVOCATION">
		<description>
			<p>This Hex allows the casting of a single Evocation spell and any cantrips</p>	
		</description>
		<setters>
			<set name="category">Hex Types</set>
			<set name="type" addition="any">Hex Purity</set>
			<set name="school">Evocation</set>
			<set name="hex">ID_INTERNAL_HEX_PURITY</set>
			<set name="name-format">{{parent}} {{school}}</set>
		</setters>
	</element>
</elements>
